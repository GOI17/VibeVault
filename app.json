{
  "expo": {
    "name": "VibeVault",
    "slug": "VibeVault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vibevault",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.ios.vibevault",
      "supportsTablet": true
    },
    "android": {
      "package": "com.android.vibevault",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store"
    ]
  }
}
